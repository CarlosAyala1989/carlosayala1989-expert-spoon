# MySQL 8 (la base puede crearse con `npm run db:init`)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASSWORD=contrasena_mysql
DB_NAME=educacion_interactiva
DB_SSL=false

# IA. Si queda vacío, la aplicación funciona en modo demostración.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# DeepSeek usa una API compatible con el SDK de OpenAI.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Genere un valor largo y aleatorio para producción.
SESSION_SECRET=cambie-este-valor-por-uno-largo-y-aleatorio
